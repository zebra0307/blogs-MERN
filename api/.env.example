# ===========================================
# API Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGO=mongodb+srv://username:password@cluster.mongodb.net/database_name

# JWT Secret (Generate a random string)
JWT_SECRET=your_jwt_secret_key_here

# Brevo Email Service (for OTP emails)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=your_verified_sender_email@example.com
BREVO_FROM_NAME=Your App Name

# Server Port (optional, defaults to 3000)
PORT=3000

# CORS allowed origins (optional)
# Accepted formats:
# 1) Comma-separated: CORS_ORIGINS=https://z-blogs.vercel.app,https://www.yourdomain.com
# 2) JSON array: CORS_ORIGINS=["https://z-blogs.vercel.app","https://www.yourdomain.com"]
# Avoid trailing slashes.
CORS_ORIGINS=http://localhost:5173

# Set true only if backend should also serve the built frontend from client/dist
SERVE_CLIENT=false
