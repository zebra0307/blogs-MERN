# ===========================================
# Client Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Backend API URL
# Production backend: VITE_BACKEND_URL=https://z-blogs.onrender.com
# Local development backend: VITE_BACKEND_URL=http://localhost:3000
VITE_BACKEND_URL=https://z-blogs.onrender.com

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
